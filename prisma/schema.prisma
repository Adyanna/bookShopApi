generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  author      String
  status      String
  ownerId     Int  
  user        User     @relation(fields:[ownerId],references:[id])
  soldAt      DateTime?
  createdAt   DateTime @default(now())
}


model User {
  id          Int      @id @default(autoincrement())
  lastName    String
  firstName   String
  email       String   @unique
  password    String
  product     Book[]
  createdAt   DateTime @default(now())
}